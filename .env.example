# ---------------------------------------------------------------------------
# OCR Engine
# ---------------------------------------------------------------------------

# Engine to use: tesseract | paddleocr
OCR_ENGINE=tesseract

# Path to tesseract binary
TESSERACT_CMD=/usr/bin/tesseract

# Default OCR language (ISO 639-2/T code, e.g. eng, spa, fra)
DEFAULT_OCR_LANGUAGE=eng

# ---------------------------------------------------------------------------
# File Limits
# ---------------------------------------------------------------------------

# Maximum upload / download size in MB
MAX_FILE_SIZE_MB=20
MAX_DOWNLOAD_SIZE_MB=20

# ---------------------------------------------------------------------------
# URL Download
# ---------------------------------------------------------------------------

# Timeout in seconds for remote URL downloads
DOWNLOAD_TIMEOUT_SECONDS=30

# Comma-separated list of allowed URL schemes
ALLOWED_URL_SCHEMES=["http","https"]

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------

# Directory for temporary files (auto-created on startup)
TEMP_DIR=/tmp/ocr_processor

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Number of uvicorn workers
WORKERS=4

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# CORS origins (JSON list). Use ["*"] to allow all in development.
# In production, restrict to known frontend origins.
CORS_ORIGINS=["*"]
